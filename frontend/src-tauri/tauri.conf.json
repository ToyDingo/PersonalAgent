{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "PersonalAgent",
  "version": "0.1.0",
  "identifier": "com.personalagent.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "PersonalAgent",
        "width": 1440,
        "height": 920,
        "minWidth": 1120,
        "minHeight": 760,
        "resizable": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' asset: https: data:; style-src 'self' 'unsafe-inline'; connect-src 'self' https: http://127.0.0.1:* ws://127.0.0.1:*;"
    }
  },
  "bundle": {
    "active": true,
    "category": "Productivity",
    "shortDescription": "Agentic calendar assistant for desktop",
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}

